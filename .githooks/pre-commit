#!/bin/bash
set -e

PUBLIC_KEY="age18hvl9tpxptpc5zk5hn2zmvqhe4zf9gc4zphupdlttfcxml4ue4ksuq2wgl"
SOPS_VERSION="v3.13.0"
BIN_DIR="$HOME/.sops-bin"
SOPS_PATH="$BIN_DIR/sops.exe"

if [ ! -f "$SOPS_PATH" ]; then
    echo "SOPS pro Windows nebyl nalezen. Stahuji automaticky..."
    mkdir -p "$BIN_DIR"
    curl -fL -o "$SOPS_PATH" "https://github.com/getsops/sops/releases/download/$SOPS_VERSION/sops-$SOPS_VERSION.amd64.exe"
    echo "SOPS úspěšně stažen."
fi

STAGED_ENC_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.enc\.env$' || true)

for file in $STAGED_ENC_FILES; do
    if [ -f "$file" ]; then

      #přidat sem tu kontrolu jestli už to není zašifrovaný když se třeba ten commit neudělá, ale nějaký soubor už to zašifruje - nebo ono to asi samo neprojde
      #šifrovat pro každý prostředí zvlášť každý jiným klíčem
      #když přidávám nový soubor tak je potřeba nastavit konec řádků na LF

            sed -i "s/\r//" "$file" #nastavení konců řádků na LF

            echo "Hook detekoval změnu v $file. Šifruji na místě..."

            "$SOPS_PATH" --encrypt --age "$PUBLIC_KEY" "$file" > "$file.tmp"

            mv "$file.tmp" "$file"

            git add "$file"

            echo " Soubor $file byl přepsán šifrou."

            FILE_HASH=$(md5sum "$file" | awk '{print $1}')

            APP_NAME=$(basename "$file" ".enc.env") # zjistíme jméno aplikace

            if [[ "$file" =~ envs/([^/]+)/ ]]; then

                ENV_NAME="${BASH_REMATCH[1]}"
                COMPOSE_FILE="apps/$APP_NAME/compose.${ENV_NAME}.yml"
                SED_TARGET="env_hash"
            else

                COMPOSE_FILE="apps/$APP_NAME/compose.yml"
                SED_TARGET="env_hash_main"
            fi

            if [ -f "$COMPOSE_FILE" ]; then
                echo "Aktualizuji hash v $COMPOSE_FILE"

                sed -i "s/${SED_TARGET}=.*/${SED_TARGET}=$FILE_HASH/" "$COMPOSE_FILE"

                git add "$COMPOSE_FILE"
            else
                echo "Compose soubor $COMPOSE_FILE nebyl nalezen, hash nelze zapsat."
                exit 1
            fi

    fi
done